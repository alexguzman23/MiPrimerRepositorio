Algoritmo Ejercicio5
	
	Definir Numero1 Como Entero
	Numero1 = 1
	
	Escribir " Ingrese un numero del 1 al 10 "
	
	Mientras Numero1 >= 1 Y Numero1 <= 10 Hacer
		
		Leer Numero1
		
		si Numero1 >= 1 Y Numero1 <= 10 Entonces
			
			Escribir " Te encuentras en un bucle para salir ingrese un numero invalido "
		
		SiNo
			Escribir " Numero incorrecto salio del bucle "
		FinSi
		
		
	Fin Mientras
FinAlgoritmo
